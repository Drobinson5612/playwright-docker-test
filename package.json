{
  "name": "playwright-docker-test",
  "version": "1.0.0",
  "description": "Containerized TypeScript app for web scraping IPO data using Playwright",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --project=chromium-ui --project=firefox-ui --project=webkit-ui",
    "test:api": "npx playwright test --project=api-tests",
    "test:api:health": "npx playwright test tests/api/health.spec.ts --project=api-tests",
    "test:all": "npx playwright test",
    "test:report": "npx playwright show-report"
  },
  "keywords": [
    "playwright",
    "docker",
    "typescript",
    "web-scraping"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.41.0"
  }
}
