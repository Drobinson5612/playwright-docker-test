# Prompt Helper API Configuration
# Base URL for the Prompt Helper API
PROMPT_HELPER_API_URL=http://host.docker.internal:5000

# Test Configuration
TEST_TIMEOUT=30000
TEST_RETRIES=1

# Test Data Configuration
CLEANUP_TEST_DATA=true
TEST_DATA_PREFIX=test_

# Optional: Authentication (if required by API)
# API_KEY=your_api_key_here
# API_TOKEN=your_token_here
